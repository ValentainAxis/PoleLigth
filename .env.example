# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Path to your Firebase service account JSON file (relative or absolute)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Realtime Database URL
# Format: https://your-project-name.firebaseio.com
FIREBASE_DATABASE_URL=https://your-project-name.firebaseio.com

# Node Environment
NODE_ENV=development

# Server Port (optional, defaults to 3000 in server.ts)
PORT=3000